{
  "permissions": {
    "allow": [
      "PowerShell(Get-PSDrive -PSProvider FileSystem | Select-Object Name, @{N='Free\\(GB\\)';E={[math]::Round\\($_.Free/1GB,1\\)}}, @{N='Used\\(GB\\)';E={[math]::Round\\(\\($_.Used\\)/1GB,1\\)}})",
      "PowerShell(Get-PSDrive C,D -PSProvider FileSystem | Select-Object Name, @{N='Free\\(GB\\)';E={[math]::Round\\($_.Free/1GB,2\\)}}, @{N='Used\\(GB\\)';E={[math]::Round\\($_.Used/1GB,2\\)}})",
      "Read(//mnt/**)",
      "Bash(powershell.exe -NoProfile -Command ' *)",
      "PowerShell(Invoke-WebRequest -Uri \"http://localhost:3000/design-agent\" -UseBasicParsing -TimeoutSec 10 | Select-Object -ExpandProperty StatusCode)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/design-agent)",
      "Bash(timeout 40 bash -c 'until curl -sf http://localhost:3000 >/dev/null 2>&1; do sleep 2; done && echo ready')",
      "Bash(curl -sf http://localhost:3000/timeline)",
      "Bash(curl *)",
      "Bash(npx tsc *)"
    ]
  }
}
